    mHideTimer.TickSignal().Connect(this, &ScrollBarImpl::OnHideTimerFired);
    mHideTimer.Start();
  }
}

bool ScrollBarImpl::OnHideTimerFired()
{
  PlayFadeOut();
  return false; // one-shot: do not repeat
}

