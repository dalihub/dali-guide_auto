     */
    VERTICAL_ALIGNMENT,

    /**
     * @brief The overflow mode.
     * @details Name "overflowMode", type Text::OverflowMode (Property::INTEGER) or Property::STRING.
     * @note Return type is Text::OverflowMode (Property::INTEGER).
