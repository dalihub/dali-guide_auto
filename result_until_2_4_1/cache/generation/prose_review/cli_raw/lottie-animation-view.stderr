// JumpToFrame

int UtcDaliLottieAnimationViewJumpToFrameP(void)
{
  UiTestApplication application;
  LottieAnimationView view = LottieAnimationView::New();

  // Should not crash even without visual
  view.JumpToFrame(10);
  DALI_TEST_CHECK(view);

  view.JumpToFrame(0);
  DALI_TEST_CHECK(view);

  view.JumpToFrame(50);
  DALI_TEST_CHECK(view);
  END_TEST;
}

