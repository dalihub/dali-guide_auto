      case ViewType::ANIMATED: return GIF_URLS[mImageIndex % GIF_COUNT];
      case ViewType::LOTTIE:   return LOTTIE_URLS[mImageIndex % LOTTIE_COUNT];
      default:                  return IMAGE_URLS[mImageIndex % IMAGE_COUNT];
