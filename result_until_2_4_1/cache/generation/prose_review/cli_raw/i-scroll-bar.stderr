  {
    return mBarMinSize;
  }
  float size = std::max(Self().GetProperty<float>(Actor::Property::SIZE_WIDTH),
                        Self().GetProperty<float>(Actor::Property::SIZE_HEIGHT));
  return std::max(1.0f, size / 20.0f);
}

