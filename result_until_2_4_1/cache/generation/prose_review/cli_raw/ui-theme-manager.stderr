int UtcDaliUiThemeManagerGetSingletonP(void)
{
  UiTestApplication application;

  UiThemeManager manager1 = UiThemeManager::Get();
  UiThemeManager manager2 = UiThemeManager::Get();

  DALI_TEST_CHECK(manager1);
