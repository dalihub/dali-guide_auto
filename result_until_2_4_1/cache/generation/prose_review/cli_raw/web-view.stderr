void WebViewImpl::LoadUrl(const Dali::String& url)
{
  if(mWebEngine)
  {
    DALI_LOG_DEBUG_INFO("[WebViewImpl] LoadUrl: %s\n", url.CStr());
    mWebEngine.LoadUrl(ToStdString(url));
  }
}

void WebViewImpl::LoadHtmlString(const Dali::String& htmlString)
