tring(cursorWidth).c_str();\n    status += \"\\nMax:\";\n    status += std::to_string(maximumLength).c_str();\n    status += \" Edit:\";\n    status += (editable ? \"ON\" : \"OFF\");\n    status += \" Sel:\";\n    status += (selectionEnabled ? \"ON\" : \"OFF\");\n    status += \" [\";\n    status += std::to_string(selStart).c_str();\n    status += \"-\";\n    status += std::to_string(selEnd).c_str();",
