  View CreatePanel(const char* title, bool cropToMask, int panelIdx)
  {
    ImageView::New(STATIC_URL)
      .SetRequestedWidth(cropToMask ? WRAP_CONTENT : MATCH_PARENT)
      .SetRequestedHeight(WRAP_CONTENT)
