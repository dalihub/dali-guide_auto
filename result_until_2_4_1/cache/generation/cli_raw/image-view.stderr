  DALI_TEST_EQUALS(view.GetMaskingMode(), Ui::Image::MaskingType::MASKING_ON_LOADING, TEST_LOCATION);
  view.SetMaskingMode(Ui::Image::MaskingType::MASKING_ON_RENDERING);
