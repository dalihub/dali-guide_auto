   *
   * @param[in] internal A pointer to the internal CustomActor
   */
  explicit DALI_UI_API Layout(Dali::Internal::CustomActor* internal);
  /// @endcond

public:
  DALI_UI_CHAIN_VIEW_METHODS(Layout)
};

