    /**
     * @brief Quick spring, Fast settling animation with minimal overshoot.
     * @SINCE_2_4.17
     */
    QUICK,

    /**
     * @brief Bouncy spring. Highly elastic and oscillatory animation.
     * @SINCE_2_4.17
     */
    BOUNCY,

    /**
     * @brief Slow spring. Smooth and relaxed motion with longer settling.
     * @SINCE_2_4.17
     */
    SLOW
  };

