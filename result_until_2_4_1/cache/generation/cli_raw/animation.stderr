   * @SINCE_1_9.22
   * @param[in] rhs A reference to the moved handle
   */
  Animation(Animation&& rhs) noexcept;

  /**
   * @brief Move assignment operator.
   *
   * @SINCE_1_9.22
   * @param[in] rhs A reference to the moved handle
   * @return A reference to this handle
   */
  Animation& operator=(Animation&& rhs) noexcept;

