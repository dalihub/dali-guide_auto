AddOnManager* AddOnManager::mSingleton = nullptr;

AddOnManager::AddOnManager()
{
  mSingleton = this;
}

AddOnManager::~AddOnManager() = default;

AddOnManager* AddOnManager::Get()
{
  return mSingleton;
}
} // namespace Integration
} // namespace Dali

