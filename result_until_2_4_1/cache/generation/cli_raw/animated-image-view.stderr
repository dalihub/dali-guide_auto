          .SetRequestedWidth(64.0f)
          .SetRequestedHeight(MATCH_PARENT)
          .SetFontSize(12.0f)
          .SetTextColor(UiColor(0xAAAAAA))
          .SetVerticalTextAlignment(Text::Alignment::CENTER),
