<codeline><highlight class="normal">-<sp/>`&quot;fontFamily&quot;`</highlight></codeline>
<codeline><highlight class="normal">-<sp/>`&quot;fontSize&quot;`</highlight></codeline>
<codeline><highlight class="normal">-<sp/>`&quot;textColor&quot;`</highlight></codeline>
<codeline><highlight class="normal">-<sp/>`&quot;placeholder&quot;`</highlight></codeline>
