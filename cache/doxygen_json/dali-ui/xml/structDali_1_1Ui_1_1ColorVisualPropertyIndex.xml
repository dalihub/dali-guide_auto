</simplesect>
<simplesect kind="note"><para>The default is <ref refid="group__dali__ui__visuals_1gga3b8461f2a1da088c522dc53e1b976912ab50339a10e1de285ac99d4c3990b8693" kindref="member">CutoutPolicy::NONE</ref>. </para>
</simplesect>
</para>
