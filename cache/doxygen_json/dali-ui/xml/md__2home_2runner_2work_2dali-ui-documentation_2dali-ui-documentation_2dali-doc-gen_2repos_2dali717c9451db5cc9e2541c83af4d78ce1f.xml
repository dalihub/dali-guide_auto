</para>
</listitem><listitem><para><computeroutput>BIDI_INFO</computeroutput><itemizedlist>
<listitem><para>bidi 정보 계산</para>
</listitem></itemizedlist>
</para>
</listitem><listitem><para><computeroutput>SHAPE_TEXT</computeroutput><itemizedlist>
<listitem><para>glyph shaping</para>
</listitem></itemizedlist>
</para>
</listitem><listitem><para><computeroutput>GET_GLYPH_METRICS</computeroutput><itemizedlist>
<listitem><para>glyph metrics 수집</para>
</listitem></itemizedlist>
</para>
</listitem><listitem><para><computeroutput>LAYOUT</computeroutput><itemizedlist>
