</listitem><listitem><para><computeroutput>VALIDATE_FONTS</computeroutput></para>
</listitem><listitem><para><computeroutput>GET_LINE_BREAKS</computeroutput></para>
</listitem><listitem><para><computeroutput>BIDI_INFO</computeroutput></para>
</listitem><listitem><para><computeroutput>SHAPE_TEXT</computeroutput></para>
</listitem><listitem><para><computeroutput>GET_GLYPH_METRICS</computeroutput></para>
</listitem><listitem><para><computeroutput>LAYOUT</computeroutput></para>
</listitem><listitem><para><computeroutput>UPDATE_LAYOUT_SIZE</computeroutput></para>
</listitem><listitem><para><computeroutput>REORDER</computeroutput></para>
</listitem><listitem><para><computeroutput>ALIGN</computeroutput></para>
