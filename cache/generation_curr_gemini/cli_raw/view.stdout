  {
    mView = Dali::Ui::View::New();
    mView.SetBackgroundColor(Dali::Color::ORANGE);
    mView.SetRequestedWidth(150.0f);
    mView.SetRequestedHeight(50.0f);

    Dali::Ui::InteractiveTrait interactiveTrait = mView.AsInteractive();
    interactiveTrait.SetClickable(true); // Must be clickable for pressed state changes

    // Connect to the PressedChangedSignal
    interactiveTrait.ConnectPressedChangedSignal(this, &MyPressableView::OnPressedChanged);

    // Connect to the LongPressedSignal
    interactiveTrait.ConnectLongPressedSignal(this, &MyPressableView::OnLongPressed);
  }

  Dali::Ui::View GetView() { return mView; }

private:
  void OnPressedChanged(Dali::Ui::View view, bool pressed, const Dali::InputEvent& event)
  {
    if (pressed)
    {
      view.SetBackgroundColor(Dali::Color::RED); // Pressed state
    }
    else
    {
      view.SetBackgroundColor(Dali::Color::ORANGE); // Released state
    }
  }

  bool OnLongPressed(Dali::Ui::View view, const Dali::InputEvent& event)
  {
    view.SetBackgroundColor(Dali::Color::BLUE); // Long pressed state
    return true;
  }

  Dali::Ui::View mView;
};
```

## Managing Selection State

The `Dali::Ui::SelectableTrait` allows a `View` to manage a selection state, often used for toggling or multi-selection UI elements.

```cpp
#include <dali-ui/dali-ui.h>
#include <dali-toolkit/dali-toolkit.h> // For InputEvent

class MySelectableToggleView : public Dali::ConnectionTracker
{
public:
  MySelectableToggleView()
  {
    mView = Dali::Ui::View::New();
    mView.SetBackgroundColor(Dali::Color::LIGHT_GRAY);
    mView.SetRequestedWidth(100.0f);
    mView.SetRequestedHeight(50.0f);

    // Get the SelectableTrait from the View
    Dali::Ui::SelectableTrait selectableTrait = mView.AsSelectable();

    // Enable toggling selection by click
    selectableTrait.EnableToggleByClick(true);

    // Connect to the SelectionChangedSignal
    selectableTrait.SelectionChangedSignal().Connect(this, &MySelectableToggleView::OnSelectionChanged);
  }

  Dali::Ui::View GetView() { return mView; }

private:
  void OnSelectionChanged(Dali::Ui::View view, bool selected, const Dali::InputEvent& event)
  {
    if (selected)
    {
      view.SetBackgroundColor(Dali::Color::DARK_GRAY); // Selected state
    }
    else
    {
      view.SetBackgroundColor(Dali::Color::LIGHT_GRAY); // Deselected state
    }
  }

  Dali::Ui::View mView;
};
```

You can also programmatically set the selection state using `SetSelected()` and query it with `IsSelected()`.

```cpp
// ... inside a method of MySelectableToggleView or similar context
Dali::Ui::SelectableTrait selectableTrait = mView.AsSelectable();

// Programmatically select the view
selectableTrait.SetSelected(true);

// Check if the view is selected
bool isCurrentlySelected = selectableTrait.IsSelected();
```

## Animating Views

`Dali::Ui::View` provides an `Animate` method for performing animations on its properties. This leverages `Dali::Ui::ViewAnimationSpec` to define animation parameters. `Dali::Actor::Property` enums are used for animatable properties like position, opacity, and scale.

```cpp
#include <dali-ui/dali-ui.h>
#include <dali-toolkit/dali-toolkit.h> // For Vector2, Property::Type

Dali::Ui::View viewToAnimate = Dali::Ui::View::New();
viewToAnimate.SetBackgroundColor(Dali::Color::BLUE);
viewToAnimate.SetRequestedWidth(100.0f);
viewToAnimate.SetRequestedHeight(100.0f);
viewToAnimate.SetCurrentPosition(Dali::Vector2(50.0f, 50.0f)); // Initial position

// Create an animation specification
Dali::Ui::ViewAnimationSpec animSpec = Dali::Ui::View::NewAnimationSpec();
animSpec.SetDuration(0.5f); // 0.5 seconds
animSpec.SetDelay(0.1f);    // 0.1 second delay

// Animate the View's position
viewToAnimate.Animate(Dali::Actor::Property::POSITION,
                      Dali::Vector2(200.0f, 200.0f), // Target position
                      animSpec);

// Animate the View's opacity (e.g., fade out)
viewToAnimate.Animate(Dali::Actor::Property::OPACITY,
                      0.0f, // Target opacity
                      animSpec);
```
