        LottieAnimationView::DownCast(mImage).Play();
        break;
      default:
        ImageView::DownCast(mImage).SetResourceUrl(mainUrl);
        break;
    }

    mStatusLabel.SetText("Loading main image...");
    DALI_LOG_ERROR("[Placeholder] Timer fired — url=%s\n", mainUrl);

