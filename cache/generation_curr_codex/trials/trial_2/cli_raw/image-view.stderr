  Dali::Ui::ImageView::New("images/card-photo.jpg")
    .SetImageLoadWithViewSize(true)
    .SetFittingMode(Dali::Ui::Image::FittingMode::OVER_FIT_KEEP_ASPECT_RATIO);

bool usesViewSize = cardImage.IsImageLoadWithViewSizeEnabled();
```

