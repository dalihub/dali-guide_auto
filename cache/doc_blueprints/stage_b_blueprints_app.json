      {
        "section_title": "Overview",
        "description": "The DALi math module provides a robust suite of geometric and linear algebra primitives designed to handle the coordinate, transformation, and spatial requirements of high-performance UI applications."
      },
      {
        "section_title": "Working with 2D and 3D Vectors",
        "description": "Learn how to use Vector2, Vector3, and Vector4 classes for managing positional, directional, and color data in your application layouts."
      },
      {
        "section_title": "Geometric Transformations and Matrices",
        "description": "Manipulate UI elements in 3D space using Matrix and Matrix3 objects to handle scaling, rotation, translation, and coordinate system inversions."
      },
      {
        "section_title": "Rotations and Orientations",
        "description": "Utilize Quaternions and AngleAxis to perform smooth, efficient, and gimbal-lock-free object rotations and interpolations."
      },
      {
        "section_title": "Defining Spatial Areas and Bounds",
        "description": "Manage screen areas, hit-testing, and clipping boundaries effectively using the Rect class and its intersection utilities."
      },
      {
        "section_title": "Angle and Precision Utilities",
        "description": "Ensure consistent mathematical operations using dedicated Degree and Radian wrappers along with Epsilon-based comparison tools for floating-point safety."
      },
      {
        "section_title": "Data Packing and Pair Structures",
        "description": "Handle grid sizes, dimensions, and buffer values efficiently using specialized pair structures like IntPair, Int32Pair, and Uint16Pair."
      },
      {
        "section_title": "Procedural Math Helpers",
        "description": "Implement randomness and logarithmic scaling in your animations or procedural layouts using the Random and Log helper utilities."
      }
    ]
  },
