      {
        "section_title": "Overview",
        "description": "AnimatedImageView is a specialized Dali::Ui::View component designed to efficiently load, display, and manage playback for animated GIF and WEBP image formats."
      },
      {
        "section_title": "Getting Started and Loading Resources",
        "description": "Learn how to instantiate the view and define the source assets, including handling local and remote URLs for animated sequences."
      },
      {
        "section_title": "Playback Control",
        "description": "Manage the animation state using playback commands like play, pause, stop, and configure advanced behaviors such as loop counts and frame speed factors."
      },
      {
        "section_title": "Visual Configuration and Masking",
        "description": "Customize the rendering appearance of the animated image through pixel area cropping, color tinting, and dynamic alpha masking."
      },
      {
        "section_title": "Layout and Sizing",
        "description": "Control how the animated content fits within the UI container by managing desired dimensions, fitting modes, and synchronous vs. asynchronous sizing policies."
      },
      {
        "section_title": "Memory and Performance Optimization",
        "description": "Optimize application performance by configuring batch and cache sizes, load/release policies, and using placeholders during resource acquisition."
      },
      {
        "section_title": "Event Handling",
        "description": "Respond to lifecycle changes in the view by connecting to signals for resource readiness and animation playback completion."
      }
