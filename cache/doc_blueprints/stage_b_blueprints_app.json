    "outline": [
      {
        "section_title": "Overview",
        "description": "The DALi animation framework provides a powerful, high-performance system for creating fluid transitions and dynamic property changes across Dali::Ui::View components."
      },
      {
        "section_title": "Declarative UI Animations",
        "description": "Learn how to use ViewAnimationSpec and ViewAnimationBridge to quickly apply predefined motion profiles to UI layouts without manual frame management."
      },
      {
        "section_title": "Time-Based Property Interpolation",
        "description": "Master the Animation class to animate property values over time using custom keyframes, duration settings, and loop behaviors."
      },
      {
        "section_title": "Motion Shaping and Easing",
        "description": "Control the feel of your transitions by applying AlphaFunctions and SpringData to define the velocity and acceleration curves of your animations."
      },
      {
        "section_title": "Dynamic Relationship Constraints",
        "description": "Create complex, reactive UI behaviors by linking property values between views using constraints and linear constrainers."
      },
      {
        "section_title": "Path-Based Movement",
        "description": "Implement non-linear movement by defining Path objects that guide views along complex trajectories in 2D or 3D space."
      },
      {
        "section_title": "Animation Control and Lifecycle",
        "description": "Manage the playback state of your animations, including pausing, looping, and seeking to specific progress points."
      }
    ]
  },
