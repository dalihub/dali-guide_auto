        "section_title": "Overview",
        "description": "AnimatedImageView is a specialized Dali::Ui::View component designed to efficiently load, display, and manage playback for animated GIF and WEBP image resources within a DALi interface."
      },
      {
        "section_title": "Initialization and Resource Loading",
        "description": "Learn how to instantiate the view and manage image source URLs, including support for placeholders and batch loading configurations."
      },
      {
        "section_title": "Playback Control and Animation State",
        "description": "Manage the lifecycle of animated content using playback commands like play, pause, and stop, alongside granular control over frame speed and loop behavior."
      },
      {
        "section_title": "Visual Configuration and Effects",
        "description": "Apply visual adjustments to the animated content, such as tinting colors, alpha masking, cropping, and fitting modes to suit your application's design."
      },
      {
        "section_title": "Layout and Sizing Preferences",
        "description": "Configure the spatial properties of the view, including target dimensions and image-specific sizing policies that ensure optimal rendering performance."
      },
      {
        "section_title": "Performance and Memory Management",
        "description": "Optimize resource usage by adjusting loading policies, synchronous versus asynchronous loading, and frame caching parameters."
      },
      {
        "section_title": "Event Handling and Signaling",
        "description": "Integrate your application logic with the view by listening for completion signals and tracking resource readiness or specific frame navigation events."
      }
