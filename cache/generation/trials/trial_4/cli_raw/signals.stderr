), 0.0f, TEST_LOCATION);\n  DALI_TEST_EQUALS(desired.GetHeight(), 0.0f, TEST_LOCATION);\n  END_TEST;\n}\n```\n\nOptional source files to inspect if needed:\n[\n  {\n    \"kind\": \"utc\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"FocusManager\",\n      \"Get\",\n      \"GetCurrentFocusView\",\n      \"Layout\",\n      \"LayoutRect\",\n      \"MoveFocus\",\n      \"RequestFocus\",\n      \"SetAsFocusGroup\",\n      \"SetCurrentFocusView\",\n      \"StackLayout\"\n    ],\n    \"path\": \"repos/dali-ui/automated-tests/src/dali-ui-foundation/utc-Dali-FocusManager.cpp\",\n    \"relevance\": \"strong\",\n    \"score\": 0.75,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 98,\n    \"snippet_start_line\": 19\n  },\n  {\n    \"kind\": \"utc\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"ClearFocus\",\n      \"FocusChangedSignal\",\n      \"FocusManager\",\n      \"Get\",\n      \"GetCurrentFocusView\",\n      \"LayoutRect\",\n      \"MoveFocus\",\n      \"SetCurrentFocusView\",\n      \"StackLayout\"\n    ],\n    \"path\": \"repos/dali-ui/automated-tests/src/dali-ui-foundation/utc-Dali-View.cpp\",\n    \"relevance\": \"medium\",\n    \"score\": 0.7,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 771,\n    \"snippet_start_line\": 692\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"FocusChangedSignal\",\n      \"StackLayout\"\n    ],\n    \"path\": \"repos/dali-ui/samples/text/text-marquee-example.cpp\",\n    \"relevance\": \"medium\",\n    \"score\": 0.6,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 116,\n    \"snippet_start_line\": 37\n  },\n  {\n    \"kind\": \"utc\",\n  