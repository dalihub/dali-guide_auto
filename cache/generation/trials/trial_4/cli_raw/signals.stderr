anim.gif     (animated GIF)\n *   2. animatedLoading.gif    (animated GIF)\n *   3. URL Array: dog-anim-001~008.png     (8 PNG frames via SetResourceUrls)\n *   4. URL Array: dali-logo-anim-001~015.png  (15 PNG frames via SetResourceUrls)\n *\n * Press Escape or Back to quit.\n```\n\n- repos/dali-ui/samples/image-view/image-alpha-mask-example.cpp:19 (sample, score=1.0)\n```cpp\n#include <dali-ui-foundation/public-api/layouts/stack-layout-params.h>\n#include <dali-ui-foundation/public-api/layouts/stack-layout.h>\n#include <dali/integration-api/debug.h>\n\nusing namespace Dali;\nusing namespace Dali::Ui;\n\n/**\n * AlphaMask sample — tests ImageView and AnimatedImageView:\n * - Left panel : CropToMask=false — full image with mask alpha applied\n * - Right panel: CropToMask=true  — image cropped to mask bounding box\n * - IMAGE TYPE button: toggle between static (ImageView) and animated (AnimatedImageView)\n * - MASK buttons: switch between two mask shapes (CIRCLE, BUBBLE)\n * - MODE button: toggle MaskingMode between ON_RENDERING and ON_LOADING\n * - Press Escape or Back to quit\n */\nclass ImageAlphaMaskController : public ConnectionTracker\n{\n  // ── Constants ─────────────────────────────────────────────────────────────\n\n  static constexpr int PANEL_CROP_OFF = 0;\n  static constexpr int PANEL_CROP_ON  = 1;\n  static constexpr int PANEL_COUNT    = 2;\n  static constexpr int MASK_COUNT     = 2;\n```\n\nOptional source files to inspect if needed:\n[\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"AnimatedImage\",\n      \"Application\",\n      \"CENTER\",\n      \"CURRENT_FRAME\",\n      \"ConnectionTracker\",\n      \"DownCast\",\n      \"FIRST_FRAME\",\n      \"Image\",\n      \"InputEvent\",\n      \"LAST_FRAME\",\n      \"New\",\n      \"PLAYING\",\n      \"PlayState\",\n      \"ResourceReadySignal\",\n      \"SetResourceUrl\",\n      \"StopBehavior\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/animated-image-view-example.cpp\",\n    \"relevance\": \"strong\",\n    \"score\": 1.0,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 101,\n    \"snippet_start_line\": 22\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"Application\",\n      \"CENTER\",\n      \"ConnectionTracker\",\n      \"FittingMode\",\n      \"IMAGE\",\n      \"Image\",\n      \"ImageView\",\n      \"InputEvent\",\n      \"New\",\n      \"Reload\",\n      \"SetAlphaMaskUrl\",\n      \"SetCropToMask\",\n      \"SetFittingMode\",\n      \"SetMaskingMode\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/image-alpha-mask-example.cpp\",\n    \"relevance\": \"strong\",\n    \"score\": 1.0,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 98,\n    \"snippet_start_line\": 19\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"Application\",\n      \"CENTER\",\n      \"ConnectionTracker\",\n      \"DownCast\",\n      \"FittingMode\",\n      \"IMAGE\",\n      \"Image\",\n      \"ImageView\",\n      \"InputEvent\",\n      \"New\",\n      \"SetFittingMode\",\n      \"SetImageColor\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/image-color-example.cpp\",\n    \"relevance\": \"strong\",\n    \"score\": 1.0,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 99,\n    \"snippet_start_line\": 20\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"Application\",\n      \"CENTER\",\n      \"ConnectionTracker\",\n      \"FittingMode\",\n      \"Image\",\n      \"ImageView\",\n