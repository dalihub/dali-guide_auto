ker\n{\n  static constexpr int POLICY_COUNT      = 3;\n  static constexpr int LOAD_POLICY_COUNT = 2;\n\n  enum class ViewType\n  {\n    IMAGE_VIEW = 0,\n    ANIMATED_IMAGE_VIEW,\n    LOTTIE_ANIMATION_VIEW,\n    COUNT\n  };\n\n  struct PolicyEntry { const char* name; Ui::Image::ReleasePolicy policy; };\n```\n\nOptional source files to inspect if needed:\n[\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"AnimatedImageView\",\n      \"Application\",\n      \"ConnectionTracker\",\n      \"StackLayoutParams\",\n      \"callback\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/animated-image-view-example.cpp\",\n    \"relevance\": \"strong\",\n    \"score\": 0.75,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 97,\n    \"snippet_start_line\": 18\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"AnimatedImageView\",\n      \"Application\",\n      \"ConnectionTracker\",\n      \"StackLayoutParams\",\n      \"callback\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/image-loading-policy-example.cpp\",\n    \"relevance\": \"strong\",\n    \"score\": 0.75,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 99,\n    \"snippet_start_line\": 20\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"AnimatedImageView\",\n      \"Application\",\n      \"ConnectionTracker\",\n      \"StackLayoutParams\",\n      \"property\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/image-pixel-area-example.cpp\",\n    \"relevance\": \"strong\",\n    \"score\": 0.75,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 112,\n    \"snippet_start_line\": 33\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"AnimatedImageView\",\n      \"Application\",\n      \"ConnectionTracker\",\n      \"StackLayoutParams\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/image-alpha-mask-example.cpp\",\n    \"relevance\": \"medium\",\n    \"score\": 0.7,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 98,\n    \"snippet_start_line\": 19\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"AnimatedImageView\",\n      \"Application\",\n      \"ConnectionTracker\",\n      \"StackLayoutParams\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/image-color-example.cpp\",\n    \"relevance\": \"medium\",\n    \"score\": 0.7,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 99,\n    \"snippet_start_line\": 20\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"AnimatedImageView\",\n      \"Application\",\n      \"ConnectionTracker\",\n      \"StackLayoutParams\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/image-fitting-mode-example.cpp\",\n    \"relevance\": \"medium\",\n    \"score\": 0.7,\n    \"selection_reason\": \"symbol_and_path_match\",\n    \"snippet_end_line\": 118,\n    \"snippet_start_line\": 39\n  },\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"AnimatedImageView\",\n      \"Application\",\n      \"ConnectionTracker\",\n      \"StackLayoutParams\"\n    ],\n    \"path\": \"repos/dali-ui/samples/image-view/image-placeholder-example.