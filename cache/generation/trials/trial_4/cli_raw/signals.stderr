ABLE_VIEW_ID, BORDERLINE, BORDERLINE_COLOR, BORDERLINE_OFFSET, BORDERLINE_WIDTH, CLOCKWISE_FOCUSABLE_VIEW_ID, CORNER_RADIUS, CORNER_RADIUS_POLICY, CORNER_SQUARENESS, COUNTER_CLOCKWISE_FOCUSABLE_VIEW_ID, DISPATCH_KEY_EVENTS, DOWN_FOCUSABLE_VIEW_ID, FOCUS_GROUP, FORWARD_FOCUSABLE_VIEW_ID, INNER_SHADOW, LAYOUT_MODE, LEFT_FOCUSABLE_VIEW_ID, MARGIN, MAXIMUM_HEIGHT, MAXIMUM_WIDTH, MINIMUM_HEIGHT, MINIMUM_WIDTH, OFFSCREEN_RENDERING, PADDING, REQUESTED_HEIGHT, REQUESTED_WIDTH, RIGHT_FOCUSABLE_VIEW_ID, SHADOW\n\nPreferred usage patterns:\n[\n  {\n    \"avoid_symbols\": [],\n    \"id\": \"view_interaction\",\n    \"intent\": \"Make a View respond to input through the interactive trait.\",\n    \"preferred_symbols\": [\n      \"Dali::Ui::View::AsInteractive\",\n      \"Dali::Ui::InteractiveTrait::ConnectClickedSignal\",\n      \"Dali::Ui::InteractiveTrait::ConnectPressedChangedSignal\"\n    ],\n    \"property_values\": [],\n    \"source\": \"generation_config\",\n    \"usage_note\": \"Obtain the trait from View, then connect signals on the trait. Do not pass trait objects to unrelated effect APIs.\"\n  },\n  {\n    \"avoid_symbols\": [],\n    \"id\": \"view_animation\",\n    \"intent\": \"Animate a View using the dali-ui app-facing animation API.\",\n    \"preferred_symbols\": [\n      \"Dali::Ui::View::Animate\"\n    ],\n    \"property_values\": [\n      \"Dali::Actor::Property::OPACITY\",\n      \"Dali::Actor::Property::POSITION\",\n      \"Dali::Actor::Property::SCALE\"\n    ],\n    \"source\": \"generation_config\",\n    \"usage_note\": \"Use View as the object being animated. Inherited transform property enums are owned by Dali::Actor::Property.\"\n  }\n]\n\nConstraints:\n{\n  \"avoid_idioms_unless_needed\": [\n    \"raw_actor_set_property\"\n  ],\n  \"forbidden_claims\": [],\n  \"prefer_idioms\": [\n    \"fluent_chaining\",\n    \"typed_setters\",\n    \"view_tree\"\n  ]\n}\n\nShort verified evidence snippets:\n- repos/dali-ui/samples/absolutelayout/absolutelayout-example.cpp:23 (sample, score=1.0)\n```cpp\n*\n * Children are placed at explicit (x, y) coordinates with explicit sizes.\n * - Red box at top-left (20, 20)\n * - Green box at center area (150, 200)\n * - Blue box at bottom-right area (280, 400)\n *\n * Press Escape or Back to quit.\n */\nclass AbsoluteLayoutController : public ConnectionTracker\n{\npublic:\n  AbsoluteLayoutController(Application& application)\n    : mApplication(application)\n  {\n    mApplication.InitSignal().Connect(this, &AbsoluteLayoutController::Create);\n  }\n\n  void Create(Application application)\n  {\n    Window window = application.GetWindow();\n    window.SetBackgroundColor(Color::WHITE);\n\n    // Root: AbsoluteLayout filling the window\n    AbsoluteLayout root = AbsoluteLayout::New()\n```\n\n- repos/dali-ui/samples/absolutelayout/absolutelayout-layout-direction-example.cpp:24 (sample, score=1.0)\n```cpp\n* Same content as absolutelayout-example. A 100x50 yellow standalone\n * child at the top-left toggles the root view's LayoutDirection between\n * LEFT_TO_RIGHT and RIGHT_TO_LEFT on click. RTL flips direct children\n * horizontally; the standalone toggle button is excluded from mirroring\n * and stays at the top-left.\n *\n * Press Escape or Back to quit.\n */\nclass AbsoluteLayoutDirectionController : public ConnectionTracker\n{\npublic:\n  AbsoluteLayoutDirectionController(Application& application)\n    : mApplication(application)\n  {\n    mApplication.InitSignal().Connect(this, &AbsoluteLayoutDirectionController::Create);\n  }\n\n  void Create(Application application)\n  {\n    Window window = application.GetWindow();\n    window.SetBackgroundColor(Color::WHITE);\n\n    // Root: AbsoluteLayout filling the window\n    mRoot = AbsoluteLayout::New()\n```\n\nOptional source files to inspect if needed:\n[\n  {\n    \"kind\": \"sample\",\n    \"lookup_instruction\": \"Open this file only if more concrete usage evidence is needed.\",\n    \"matched_symbols\": [\n      \"Add\",\n      \"Applica