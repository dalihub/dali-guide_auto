bool synchronous) | scope=primary_member\n- Dali::Ui::ImageView::operator= | ImageView & operator=(ImageView &&rhs) noexcept | scope=primary_member\n- Dali::Ui::ImageView::~ImageView | ~ImageView() | scope=primary_member\n- Dali::Ui::ImageViewPropertyIndex | scope=document_as_part_of_primary_feature\n- Dali::Ui::ImageViewPropertyIndex::ALPHA_MASK_URL | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::CROP_TO_MASK | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::DESIRED_HEIGHT | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::DESIRED_WIDTH | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::FAST_TRACK_UPLOADING | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::FITTING_MODE | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::IMAGE | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::IMAGE_COLOR | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::IMAGE_LOAD_WITH_VIEW_SIZE | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::LOAD_POLICY | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::MASKING_MODE | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::N_PATCH_BORDER | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::N_PATCH_BORDER_ONLY | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::ORIENTATION_CORRECTION | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::PIXEL_AREA | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::PLACEHOLDER_IMAGE | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::PRE_MULTIPLIED_ALPHA | scope=document_as_part_of_primary_feature_member\n- Dali::Ui::ImageViewPropertyIndex::PropertyRange | scope=document_as_part_of_primary_feature_member\n\nProperty owner table:\n- Dali::Actor::Property: CLIPPING_MODE, COLOR, COLOR_ALPHA, COLOR_BLUE, COLOR_GREEN, COLOR_MODE, COLOR_RED, CONNECTED_TO_SCENE, CULLED, DRAW_MODE, HEIGHT_FOR_WIDTH, HEIGHT_RESIZE_POLICY, HIERARCHY_DEPTH, ID, INHERIT_LAYOUT_DIRECTION, INHERIT_ORIENTATION, INHERIT_POSITION, INHERIT_SCALE, IS_LAYER, IS_ROOT, KEYBOARD_FOCUSABLE, LAYOUT_DIRECTION, LEAVE_REQUIRED, MAXIMUM_SIZE, MINIMUM_SIZE, NAME, OPACITY, ORIENTATION, PADDING, PARENT_ORIGIN, PARENT_ORIGIN_X, PARENT_ORIGIN_Y, PARENT_ORIGIN_Z, PIVOT, PIVOT_X, PIVOT_Y, PIVOT_Z, POSITION, POSITION_USES_PIVOT, POSITION_X\n- Dali::Ui::ImageView::Property: ALPHA_MASK_URL, CROP_TO_MASK, DESIRED_HEIGHT, DESIRED_WIDTH, FAST_TRACK_UPLOADING, FITTING_MODE, IMAGE, IMAGE_COLOR, IMAGE_LOAD_WITH_VIEW_SIZE, LOAD_POLICY, MASKING_MODE, N_PATCH_BORDER, N_PATCH_BORDER_ONLY, ORIENTATION_CORRECTION, PIXEL_AREA, PLACEHOLDER_IMAGE, PRE_MULTIPLIED_ALPHA, RELEASE_POLICY, SAMPLING_MODE, SYNCHRONOUS_LOADING\n\nPreferred usage patterns:\n[\n  {\n    \"avoid_symbols\": [],\n    \"id\": \"view_animation\",\n    \"intent\": \"Animate a View using the dali-ui app-facing animation API.\",\n    \"preferred_symbols\": [\n      \"Dali::Ui::View::Animate\"\n    ],\n    \"property_values\": [\n      \"Dali::Actor::Property::OPACITY\",\n      \"Dali::Actor::Property::POSITION\",\n      \"Dali::Actor::Property::SCALE\"\n    ],\n    \"source\": \"generation_config\",\n    \"usage_note\": \"Use View as the object being animated. Inherited transform property enums are owned by Dali::Actor::Property.\"\n  }\n]\n\nConstraints:\n{\n  \"avoid_idioms_unless_needed\": [\n    \"raw_actor_set_property\"\n  ],\n  \"forbidden_claims\": [],\n  \"prefer_idioms\": [\n    \"fluent_chaining\",\n    \"typed_setters\",\n    \"view_tree\"\n  ]\n}\n\nShort verified evidence snippets:\n- repos/dali-ui/samples/image-view/animated-image-view-example.cpp:22 (sample, score=1.0)\n```cpp\nusing namespace Dali;\nusing namespace Dali::Ui;\n\n/**\n * AnimatedImageView sample.\n *\n * Demonstrates:\n *   - Play / Pause / Stop / JumpToFrame\n *   - Change Image  (cycles through WebP, GIF×2, URL array)\n *   - LoopCount  (infinite / 3 / 1)\n *   - FrameSpeedFactor  (0.5× / 1.0× / 2.0×)\n *   - StopBehavior  (CURRENT / FIRST / LAST)\n *   - SetFrameDelay  (200ms / 500ms / 1000ms / 2000ms)\n *   - GetPlayState / GetCurrentFrame / GetTotalFrame  (logged on each button press)\n *   - AnimationFinishedSignal\n *\n * Image sources:\n *   0. dog-anim.webp          (animated WebP)\n *   1. dali-logo-anim.gif     (animated GIF)\n *   2. animatedLoading.gif    (animated GIF)\n *   3. URL Array: dog-anim-001~008.png     (8 PNG frames via SetResourceUrls)\n *   4. URL Array: dali-logo-anim-001~015.png  (15 PNG frames via SetResourceUrls)\n *\n * Press Escape or Back to quit.\n```\n\n- repos/dali-ui/samples/image-view/image-alpha-mask-example.cpp:19 (sample, score=1.0)\n```cpp\n#include <dali-ui-foundation/public-api/layouts/stack-layout-params.h>\n#include <dali-ui-foundation/public-api/layouts/stack-layout.h>\n#include <dali/integration-api/debug.h>\n\nusing namespace Dali;\nusing namespace Dali::Ui;\n\n/**\n * AlphaMask sample — tests ImageView and AnimatedImageView:\n * - Left panel : CropToMask=false — full image with mask alpha applied\n * - Right panel: CropToMask=true  — image cropped to mask bounding box\n * - IMAGE TYPE button: toggle between static (ImageView) and animated (AnimatedImageView)\n * - MASK buttons: switch between two mask shapes (CIRCLE, BUBBLE)\n * - MODE button: toggle MaskingMode between ON_RENDERING and ON_LOADING\n * - Press Escape or Back to quit\n */\nclass ImageAlphaMaskController : public ConnectionTracker\n{\n  // ── Constants ─────────────────────────────────────────────────────────────\n\n  static constexpr int PANEL_CROP_OFF = 0;\n  static con