  DALI_TEST_EQUALS(view.GetMouseEventsEnabled(), true, TEST_LOCATION);
  view.SetMouseEventsEnabled(false);
  DALI_TEST_EQUALS(view.GetMouseEventsEnabled(), false, TEST_LOCATION);
