  WebView view = WebView::New();
  view.SetCursorEnabledByClient(true);
  view.SetCursorEnabledByClient(false);
  DALI_TEST_CHECK(view);
  END_TEST;
}

// ===========================================================================
// Input & Video
// ===========================================================================

