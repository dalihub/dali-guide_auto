  Dali::String GetUrl() const;

  /**
   * @brief Gets the user agent string.
   *
   * @return The user agent string
   */
  Dali::String GetUserAgent() const;

  /**
   * @brief Gets the scroll position.
   *
   * @return The current scroll position
   */
