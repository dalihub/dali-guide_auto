          .SetVerticalTextAlignment(Text::Alignment::CENTER),
        CreateToggleButton(LOOP_LABELS[mLoopIndex], [this](View, InputEvent) { OnLoopToggle(); }, mLoopButton),
      });
  }

  View CreateSpeedRow()
