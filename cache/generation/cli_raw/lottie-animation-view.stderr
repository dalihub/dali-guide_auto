  LottieAnimationView view = LottieAnimationView::New();

  // Default should be 1.0f
  DALI_TEST_EQUALS(view.GetFrameSpeedFactor(), 1.0f, TEST_LOCATION);

  view.SetFrameSpeedFactor(0.5f);

