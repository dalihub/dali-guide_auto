// === Constructor ===

int UtcDaliUiColorManagerConstructorP(void)
{
  UiTestApplication application;

  UiColorManager manager;
  DALI_TEST_CHECK(!manager);

  END_TEST;
}

// === Get Singleton ===

int UtcDaliUiColorManagerGetP(void)
{
  UiTestApplication application;

  UiColorManager manager = UiColorManager::Get();
  DALI_TEST_CHECK(manager);

  END_TEST;
