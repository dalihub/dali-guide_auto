s_must_be_feature_specific\": true,\n    \"avoid_mechanical_api_listing\": true,\n    \"default_object_model\": \"Use Dali::Ui::View rather than Dali::Actor for app-facing object examples.\",\n    \"guide_assumption\": \"The reader is using dali-ui to build applications.\"\n  }\n}\n\nSurface and usage rules:\n{\n  \"primary_surface\": \"dali-ui\",\n  \"rules\": [\n    \"Use dali-ui symbols as the app-facing API surface.\",\n    \"Use dali-core and dali-adaptor symbols only as setup/background unless the usage pattern explicitly marks them preferred.\",\n    \"Prefer View-based examples over raw Actor object-model examples.\"\n  ],\n  \"symbol_counts\": {\n    \"dali-ui\": 8\n  }\n}\n\nAllowed symbols for code examples:\n- Dali::Ui::AccessibilityHighlightOverlay | scope=primary\n- Dali::Ui::AccessibilityHighlightOverlay::AccessibilityHighlightOverlay | AccessibilityHighlightOverlay() | scope=primary_member\n- Dali::Ui::AccessibilityHighlightOverlay::GetOverlayMode | OverlayHighlightMode GetOverlayMode() const | scope=primary_member\n- Dali::Ui::AccessibilityHighlightOverlay::HideOverlay | void HideOverlay() | scope=primary_member\n- Dali::Ui::AccessibilityHighlightOverlay::ResetCustomHighlight | void ResetCustomHighlight() | scope=primary_member\n- Dali::Ui::AccessibilityHighlightOverlay::SetCustomHighlight | void SetCustomHighlight(Vector2 position, Vector2 size) | scope=primary_member\n- Dali::Ui::AccessibilityHighlightOverlay::SetOverlayMode | void SetOverlayMode(OverlayHighlightMode mode) | scope=primary_member\n- Dali::Ui::AccessibilityHighlightOverlay::UpdateOverlay | void UpdateOverlay(Dali::Actor &activeHighlight) | scope=primary_member\n\nProperty owner table:\n- (none)\n\nPreferred usage patterns:\n[\n  {\n    \"avoid_symbols\": [],\n    \"id\": \"accessibility-highlight-overlay_basic_setup\",\n    \"intent\": \"Create and configure the primary object using public dali-ui APIs.\",\n    \"preferred_symbols\": [\n      \"Dali::Ui::AccessibilityHighlightOverlay::SetCustomHighlight\",\n      \"Dali::Ui::AccessibilityHighlightOverlay::SetOverlayMode\"\n    ],\n    \"property_values\": [],\n    \"source\": \"static_api_shape\",\n    \"usage_note\": \"Prefer typed constructors and setters when available.\"\n  }\n]\n\nConstraints:\n{\n  \"avoid_idioms_unless_needed\": [\n    \"raw_actor_set_property\"\n  ],\n  \"forbidden_claims\": [],\n  \"prefer_idioms\": [\n    \"fluent_chaining\",\n    \"typed_setters\",\n    \"view_tree\"\n  ]\n}\n\nShort verified evidence snippets:\n- (none)\n\nOptional source files to inspect if needed:\n[]\n\nUncertainty notes for you, not for the final document:\n[\n  {\n    \"kind\": \"missing_property_owners\",\n    \"message\": \"No property owner table was available for this feature.\"\n  },\n  {\n    \"kind\": \"missing_examples\",\n    \"message\": \"No sample or UTC paths were available as example candidates.\"\n  }\n]",
