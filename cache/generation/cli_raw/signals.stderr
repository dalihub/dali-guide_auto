  template<typename Ret, typename... Args>
  Ret EmitReturn(Args... args)
  {
    Ret returnVal = Ret();

    // Guards against nested Emit() calls
    EmitGuard guard(mEmittingFlag);
    if(guard.ErrorOccurred())
    {
