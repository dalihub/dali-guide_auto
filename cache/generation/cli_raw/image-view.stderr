    DESIRED_HEIGHT,

    /**
     * @brief The load policy for the image resource.
     * @details Name "loadPolicy", type Ui::Image::LoadPolicy (Property::INTEGER).
     * @note See also: ImageView::SetLoadPolicy(), ImageView::GetLoadPolicy().
