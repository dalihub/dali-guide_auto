                        .SetSpacing(4.0f)
                        .SetRequestedWidth(MATCH_PARENT)
                        .SetRequestedHeight(60.0f)
                        .SetPadding(Extents(4, 4, 4, 4));
    for(int i = 0; i < MASK_COUNT; ++i)
    {
      row.Add(CreateMaskButton(i));

