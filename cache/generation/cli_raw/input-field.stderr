   */
  InputField(InputField&& rhs) noexcept;

  /**
   * @brief Virtual destructor.
   *
   * This is non-virtual since derived Handle types must not contain data or virtual methods.
   */
  ~InputField();

public: // Operators
  /**
   * @brief Copy assignment operator.
