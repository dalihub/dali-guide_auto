      TYPING_FONT_WIDTH                    = Text::InputFieldPropertyIndex::TYPING_FONT_WIDTH,
      TYPING_FONT_SLANT                    = Text::InputFieldPropertyIndex::TYPING_FONT_SLANT
    };
