using ChangedSignalType    = Dali::Signal<void(Dali::Ui::View, int)>;
using InterceptSignalType  = Dali::Signal<bool(Dali::Ui::View, int)>;
using CompletedSignalType  = Dali::Signal<bool()>;
```

