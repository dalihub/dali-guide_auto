  }

  void OnClicked(Dali::Ui::View view, Dali::Ui::InputEvent event)
  {
    ++mClickCount;

    (void)view;
    (void)event;
  }

  bool OnLongPressed(Dali::Ui::View view, Dali::Ui::InputEvent event)
  {
    ++mLongPressCount;

    (void)view;
    (void)event;

    return true;

