Dali::Ui::ImageVisual MakeThumbnailVisual()
{
  return Dali::Ui::ImageVisual::New()
    .SetName(Dali::String("thumbnail"))
    .SetResourceUrl(Dali::String("/opt/usr/apps/org.example/res/thumb.jpg"))

