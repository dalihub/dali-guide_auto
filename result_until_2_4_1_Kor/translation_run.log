  blur.SetBlurOnce(true);
  return blur;
}

GaussianBlurEffect CreateLiveContentBlur()
{
  GaussianBlurEffect blur = GaussianBlurEffect::New(12u);
  blur.SetBlurOnce(false);
  return blur;
}
```

