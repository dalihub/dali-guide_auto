            .SetVerticalTextAlignment(Text::Alignment::CENTER)
            .SetRequestedWidth(MATCH_PARENT)
            .SetLayoutParams(StackLayoutParams::New().SetWeight(1.0f))
            .SetPadding(Extents(VIEW_PADDING, VIEW_PADDING, VIEW_PADDING, VIEW_PADDING))
