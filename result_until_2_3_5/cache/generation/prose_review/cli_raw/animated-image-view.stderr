// GetLoadingStatus

int UtcDaliAnimatedImageViewGetLoadingStatusP(void)
{
  UiTestApplication application;
  AnimatedImageView view = AnimatedImageView::New("animation.gif");
  // Before scene add, status may be PREPARING, READY, or FAILED
