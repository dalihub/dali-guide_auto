};

class AsyncImageLoader : public BaseObject, public ConnectionTracker
{
public:
  /**
   * Constructor
   */
  AsyncImageLoader();

  /**
   * @copydoc Ui::AsyncImageLoader::New()
   */
  static IntrusivePtr<AsyncImageLoader> New();

