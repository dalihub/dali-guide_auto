ImageView::ImageView(Integration::ImageViewImpl& implementation)
: View(implementation)
{
}

ImageView::ImageView(Dali::Internal::CustomActor* internal)
: View(internal)
{
  VerifyCustomActorPointer<Integration::ImageViewImpl>(internal);
}

