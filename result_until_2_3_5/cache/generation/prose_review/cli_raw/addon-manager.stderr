\n      \"symbol_id\": \"Dali::Integration::AddOnManager::EnumerateAddOns\",\n      \"usage_scope\": \"primary_member\"\n    },\n    {\n      \"display_name\": \"Get\",\n      \"header_path\": \"repos/dali-core/dali/integration-api/addon-manager.h\",\n      \"kind\": \"method\",\n      \"public_api\": true,\n      \"signature\": \"AddOnManager * Get()\",\n      \"surface\": \"dali-core\",\n      \"symbol_id\": \"Dali::Integration::AddOnManager::Get\",\n      \"usage_scope\": \"primary_member\"\n    },\n    {\n      \"display_name\": \"GetAddOn\",\n      \"header_path\": \"repos/dali-core/dali/integration-api/addon-manager.h\",\n      \"kind\": \"method\",\n      \"public_api\": true,\n      \"signature\": \"AddOnLibrary GetAddOn(const std::string &addonName)\",\n      \"surface\": \"dali-core\",\n      \"symbol_id\": \"Dali::Integration::AddOnManager::GetAddOn\",\n      \"usage_scope\": \"primary_member\"\n    },\n    {\n      \"display_name\": \"GetAddOnInfo\",\n      \"header_path\": \"repos/dali-core/dali/integration-api/addon-manager.h\",\n      \"kind\": \"method\",\n      \"public_api\": true,\n      \"signature\": \"bool GetAddOnInfo(const std::string &name, AddOnInfo &info)=0\",\n      \"surface\": \"dali-core\",\n      \"symbol_id\": \"Dali::Integration::AddOnManager::GetAddOnInfo\",\n      \"usage_scope\": \"primary_member\"\n    },\n    {\n      \"display_name\": \"GetGlobalProc\",\n      \"header_path\": \"repos/dali-core/dali/integration-api/addon-manager.h\",\n      \"kind\": \"method\",\n      \"public_api\": true,\n      \"signature\": \"std::function< T > GetGlobalProc(const Dali::AddOnLibrary &addonlibrary, const char *procName)\",\n      \"surface\": \"dali-core\",\n      \"symbol_id\": \"Dali::Integration::AddOnManager::GetGlobalProc\",\n      \"usage_scope\": \"primary_member\"\n    },\n    {\n      \"display_name\": \"GetInstanceProc\",\n      \"header_path\": \"repos/dali-core/dali/integration-api/addon-manager.h\",\n      \"kind\": \"method\",\n      \"public_api\": true,\n      \"signature\": \"std::function< T > GetInstanceProc(const Dali::AddOnLibrary &addOnLibrary, const char *procName)\",\n      \"surface\": \"dali-core\",\n      \"symbol_id\": \"Dali::Integration::AddOnManager::GetInstanceProc\",\n      \"usage_scope\": \"primary_member\"\n    },\n    {\n      \"display_name\": \"InvokeGlobalProc\",\n      \"header_path\": \"repos/dali-core/dali/integration-api/addon-manager.h\",\n      \"kind\": \"method\",\n      \"public_api\": true,\n      \"signature\": \"R InvokeGlobalProc(AddOnLibrary addOnLibrary, const char *functionName, Args &&... args)\",\n      \"surface\": \"dali-core\",\n      \"symbol_id\": \"Dali::Integration::AddOnManager::InvokeGlobalProc\",\n      \"usage_scope\": \"primary_member\"\n    },\n    {\n      \"display_name\": \"LoadAddOn\",\n      \"header_path\": \"repos/dali-core/dali/integration-api/addon-manager.h\",\n      \"kind\": \"method\",\n      \"public_api\": true,\n      \"signature\": \"AddOnLibrary LoadAddOn(const std::string &addonName, const std::string &libraryName)=0\",\n      \"surface\": \"dali-core\",\n      \"symbol_id\": \"Dali::Integration::AddOnManager::LoadAddOn\",\n      \"usage_scope\": \"primary_member\"\n    },\n    {\n      \"display_name\": \"LoadAddOns\",\n      \"header_path\": \"repos/dali-core/dali/integration-api/addon-manager.h\",\n      \"kind\": \"method\",\n      \"public_api\": true,\n      \"signature\": \"std::vector< AddOnLibrary > LoadAddOns(const std::vector< std::string > &addonNames)=0\",\n      \"surface\": \"dali-core\",\n      \"symbol_id\": \"Dali::Integration::AddOnManager::LoadAddOns\",\n      \"usage_scope\": \"primary_member\"\n    },\n    {\n      \"display_name\": \"Pause\",\n      \"header_path\": \"repos/dali-core/dali/integration-api/addon-manager.h\",\n      \"kind\": \"method\",\n      \"public_api\": true,\n      \"signature\": \"void Pause()=0\",\n      \"surface\": \"dali-core\",\n      \"symbol_id\": \"Dali::Inte