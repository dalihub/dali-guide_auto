{
  if(mVisual)
  {
    Dali::Property::Map map;
    mVisual.CreatePropertyMap(map);
    if(auto* value = map.Find(Ui::ImageVisualPropertyIndex::CURRENT_FRAME_NUMBER))
    {
      return value->Get<int>();
    }
  }
  return 0;
}

