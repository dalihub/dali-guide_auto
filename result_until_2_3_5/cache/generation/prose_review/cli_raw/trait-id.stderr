    20	#include <dali-ui-foundation/public-api/dali-ui-common.h>
    21	#include <cstdint>
    22	
    23	namespace Dali
    24	{
    25	namespace Ui
    26	{
    27	
    28	/**
    29	 * @brief A lightweight handle representing a unique identifier for traits.
    30	 *
    31	 * TraitId values are allocated sequentially via TraitId::Alloc().
    32	 * Framework-reserved IDs are defined in the ReservedTraitId namespace.
    33	 * Extension or application code should allocate IDs with TraitId::Alloc()
    34	 * and store them in a static variable so each logical trait gets exactly one ID.
    35	 *
    36	 * @code
    37	 * // One-time allocation per trait type (e.g. in an anonymous namespace or as a static)
    38	 * static const TraitId kMyScrollStateTrait = TraitId::Alloc();
    39	 * @endcode
    40	 */
    41	struct DALI_UI_API TraitId
    42	{
    43	  /**
    44	   * @brief Allocates and returns the next unique TraitId.
    45	   *
    46	   * Uses an internal atomic counter. Thread-safe and lock-free.
    47	   * Call once per logical trait type and store the result statically.
    48	   *
    49	   * @return A new unique TraitId
    50	   */
    51	  static TraitId Alloc();
    52	
    53	  /**
    54	   * @brief Equality operator.
    55	   */
    56	  bool operator==(const TraitId& other) const
    57	  {
    58	    return value == other.value;
    59	  }
    60	
    61	  /**
    62	   * @brief Inequality operator.
    63	   */
    64	  bool operator!=(const TraitId& other) const
    65	  {
    66	    return value != other.value;
    67	  }
    68	
    69	  uint32_t value;
    70	
    71	private:
    72	  explicit TraitId(uint32_t v)
    73	  : value(v)
    74	  {
    75	  }
    76	};
    77	
    78	} // namespace Ui
    79	} // namespace Dali

