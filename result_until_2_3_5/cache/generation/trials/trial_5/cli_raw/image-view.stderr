  .SetPlaceholderUrl("images/loading.png")
  .SetResourceUrl("images/content.jpg");

Dali::String temporaryImageUrl = image.GetPlaceholderUrl();
Dali::Ui::Visual::ResourceStatus loadingStatus = image.GetLoadingStatus();
