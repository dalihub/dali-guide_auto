void AddOnManager::Start()
{
  for(auto& entry : mAddOnCache)
  {
    if(entry.OnStart)
    {
      entry.OnStart();
    }
  }
}

void AddOnManager::Resume()
{
  for(auto& entry : mAddOnCache)
  {
    if(entry.OnResume)
    {
      entry.OnResume();
    }
  }
}

void AddOnManager::Stop()
{
  for(auto& entry : mAddOnCache)
  {
    if(entry.OnStop)
    {
      entry.OnStop();
    }
  }
}

void AddOnManager::Pause()
{
  for(auto& entry : mAddOnCache)
  {
    if(entry.OnPause)
    {
      entry.OnPause();
    }
  }
}

