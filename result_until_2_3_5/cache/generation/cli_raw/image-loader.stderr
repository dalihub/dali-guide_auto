      <member refid="classDali_1_1Ui_1_1AsyncImageLoader_1a0a95786965df3ad53ac24a8846f891f6" prot="public" virt="non-virtual"><scope>Dali::Ui::AsyncImageLoader</scope><name>AsyncImageLoader</name></member>
