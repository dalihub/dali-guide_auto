- repos/dali-ui/automated-tests/src/dali-ui-foundation/utc-Dali-ViewState.cpp:82 (utc, score=0.45)
```cpp
{
  UiTestApplication   application;
  View              view = CreateView(application);
  ConnectionTracker tracker;

  ViewState receivedPrev, receivedCur;
  int     callCount = 0;

  IntegrationView::WhenStateChanged(GetImpl(view), "observer", &tracker, [&](View, const StateEvent& e) {
    ++callCount;
    receivedPrev = e.GetPrev();
    receivedCur  = e.GetCurrent();
  });

  IntegrationView::SetState(GetImpl(view), ViewState::FOCUSED, true);

  DALI_TEST_EQUALS(callCount, 1, TEST_LOCATION);
  DALI_TEST_CHECK(!receivedPrev.Contains(ViewState::FOCUSED));
  DALI_TEST_CHECK(receivedCur.Contains(ViewState::FOCUSED));

  END_TEST;
}

// =============================================================================
```

- repos/dali-ui/automated-tests/src/dali-ui-foundation/utc-Dali-ViewStateHandler.cpp:57 (utc, score=0.4)
```cpp
struct StateChangedFunctor
{
  StateChangedFunctor(StateChangedData& data)
  : mData(data)
  {
  }

  void operator()(View view, const StateEvent& e)
  {
    ++mData.callCount;
    mData.view = view;
    mData.prev = e.GetPrev();
    mData.cur  = e.GetCurrent();
  }

  StateChangedData& mData;
};

/**
 * @brief A helper class that implements ConnectionTracker for tracking signal lifetime.
 */
class StateHandlerTracker : public ConnectionTracker
{
