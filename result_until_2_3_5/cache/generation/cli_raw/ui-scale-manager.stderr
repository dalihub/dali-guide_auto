void UiScaleManagerImpl::SetScale(float scale)
{
  if(std::isnan(scale) || scale <= 0.0f)
  {
    DALI_LOG_ERROR("UiScaleManagerImpl::SetScale: invalid scale value (%f). Scale must be a positive finite number.\n", scale);
    return;
