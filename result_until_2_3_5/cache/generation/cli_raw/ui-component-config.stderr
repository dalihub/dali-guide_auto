# Default runtime environment for preprocess API LLM calls.
# pipeline.py --env or DALI_LLM_ENV can override this.
llm_environment: "external"

categories:
  - key: "views-components"
    label: "Views & Components"
    description: "User-facing View classes and visual UI components such as View, ImageView, Label, and reusable component building blocks."

  - key: "animation-motion"
    label: "Animation & Motion"
    description: "Animation APIs, transition helpers, timing, interpolation, and motion-related UI behavior."

  - key: "layout-sizing"
    label: "Layout & Sizing"
    description: "Layout containers, layout params, sizing policies, alignment, and positioning."

  - key: "input-interaction"
    label: "Input & Interaction"
    description: "Input events, focus, gestures, selectable or interactive behavior, and user interaction helpers."

  - key: "images-visuals"
    label: "Images & Visuals"
    description: "Image loading, visual rendering, effects, resources, and visual presentation APIs."

  - key: "text"
    label: "Text"
    description: "Text rendering internals, typography, font handling, text input/editing, and text utility APIs. User-facing display components may belong to Views & Components when they are primarily used as View classes."

  - key: "application-framework"
    label: "Application Framework"
    description: "Application, window, lifecycle, adaptor, and app setup APIs."

  - key: "accessibility"
    label: "Accessibility"
    description: "Accessibility surfaces, states, roles, highlight, and assistive interfaces."

  - key: "styling-theme-config"
    label: "Styling, Theme & Configuration"
    description: "Theme, configuration, color systems, style state, and UI customization APIs."

  - key: "utilities"
    label: "Utilities"
    description: "General utility types, common helpers, units, math-like support, and shared low-level definitions."

  - key: "platform-integration"
    label: "Platform & Integration"
    description: "Platform-facing, integration, adaptor, backend, or extension APIs not normally used by app developers."

  - key: "uncategorized"
    label: "Uncategorized"
    description: "Fallback category for features that require manual review."

category_overrides:
  - feature: "view"
    category: "views-components"
    reason: "Primary dali-ui app object."

  - feature: "image-view"
    category: "views-components"
    reason: "User-facing View component."

  - feature: "animation"
    category: "animation-motion"
    reason: "Primary animation guide."

  - feature: "label"
    category: "views-components"
    reason: "Label is a user-facing View component; text internals remain under Text."

llm_batching:
  max_features_per_category_batch: 40
  max_features_per_ownership_batch: 10
  max_prompt_tokens_per_llm_batch: 80000

guide_profile:
  key: "dali-ui-app"
  primary_surface: "dali-ui"
  context_surfaces:
    - "dali-core"
    - "dali-adaptor"
  prefer_idioms:
    - "fluent_chaining"
    - "typed_setters"
    - "view_tree"
  avoid_idioms_unless_needed:
    - "raw_actor_set_property"
  context_policy:
    dali-ui: "primary"
    dali-core: "reference_only"
    dali-adaptor: "reference_only"

document_feature_rules:
  features:
    - feature: "view"
      display_name: "View (Base UI Object)"
      source_package: "dali-ui"
      base_class: "Dali::Ui::View"
      description: "The primary UI object for DALi application developers. View inherits from Actor but provides a higher-level API designed for app development."

  merge_into:
    - feature: "actors"
      document_feature: "view"
      display_name: "Actor (Scene Graph Node)"
      source_package: "dali-core"
      base_class: "Dali::Actor"
      role: "background_context"
      usage_mode: "background_context"
      description: "Low-level scene graph node. In dali-ui apps, developers use View instead of Actor directly. Actor knowledge is background context."
      reason: "Actor is inherited/background context for View, not a standalone app-facing document."

    - feature: "image-view-types"
      document_feature: "image-view"
      display_name: "ImageView Types"
      source_package: "dali-ui"
      role: "type_definitions"
      usage_mode: "document_as_part_of_primary_feature"
      description: "Shared enum types for image-view family (LoadPolicy, ReleasePolicy, FittingMode, MaskingType, etc.). Documented as part of the image-view page."
      reason: "ImageView type definitions are part of the ImageView document."

    - feature: "interactive-trait"
      document_feature: "view"
      display_name: "InteractiveTrait"
      source_package: "dali-ui"
      role: "supporting_trait"
      usage_mode: "document_as_part_of_primary_feature"
      merge_mode: "full"
      description: "Click/press/long-press interaction behavior trait for View. Documented as part of the view page."
      reason: "InteractiveTrait is part of the View authoring model."

    - feature: "selectable-trait"
      document_feature: "view"
      display_name: "SelectableTrait"
      source_package: "dali-ui"
      role: "supporting_trait"
      usage_mode: "document_as_part_of_primary_feature"
      merge_mode: "full"
      description: "Selection state behavior trait for View. Documented as part of the view page."
      reason: "SelectableTrait is part of the View authoring model."

    - feature: "ui-state"
      document_feature: "view"
      display_name: "UiState"
      source_package: "dali-ui"
      role: "state_type"
      usage_mode: "document_as_part_of_primary_feature"
      merge_mode: "full"
      description: "Bitmask value type representing view states (PRESSED, SELECTED, FOCUSED, etc.). Documented as part of the view page."
      reason: "UiState belongs to View state/interaction documentation."

    - feature: "trait"
      document_feature: "view"
      display_name: "Trait"
      source_package: "dali-ui"
      role: "supporting_trait"
      usage_mode: "document_as_part_of_primary_feature"
      merge_mode: "full"
      description: "Base handle for all trait types. Documented as part of the view page."
      reason: "Trait is supporting input for View behavior traits."

  suppress:
    - feature: "custom-actor"
      display_name: "CustomActor"
      source_package: "dali-core"
      description: "Internal extension mechanism. App and platform developers do not use CustomActor directly."
      reason: "Internal extension mechanism, not app-facing documentation."

    - feature: "align-enumerations"
      display_name: "Align Enumerations"
      source_package: "dali-core"
      description: "Low-level alignment enum definitions. Not documented separately."
      reason: "Low-level enum group, not a standalone app guide."

    - feature: "callback"
      display_name: "Callback"
      source_package: "dali-core"
      description: "Internal callback utility. Not exposed as a user-facing feature."
      reason: "Internal utility, not a standalone app guide."

    - feature: "camera-view"
      display_name: "CameraView"
      source_package: "dali-ui"
      description: "Camera preview view. Not included in current documentation scope."
      reason: "Not included in the current documentation scope."

    - feature: "common"
      display_name: "Common"
      source_package: "dali-core"
      description: "Common internal definitions shared across packages. Not documented separately."
      reason: "Shared internal definitions, not a standalone app guide."

    - feature: "drawable-actor"
      display_name: "DrawableActor"
      source_package: "dali-core"
      description: "Low-level drawable actor. Platform-tier only, not for app documentation."
      reason: "Platform-tier low-level actor, not app-facing documentation."

    - feature: "dummy-component"
      display_name: "DummyComponent"
      source_package: "dali-ui"
      description: "Internal test/placeholder component. Not documented."
      reason: "Internal test/placeholder component."

    - feature: "size-negotiation"
      display_name: "Size Negotiation"
      source_package: "dali-core"
      description: "Internal size negotiation enums and types. Covered implicitly via layout documentation."
      reason: "Internal layout support types, not a standalone app guide."

  extension_surfaces:
    - feature: "view-impl"
      document_feature: "view"
      display_name: "View Impl"
      source_package: "dali-ui"
      role: "extension_surface"
      usage_mode: "advanced_extension"
      include_in_doc: true
      reason: "Used only when implementing custom View extensions."

  suffix_absorption:

