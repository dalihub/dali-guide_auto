 * @brief Enumeration for font weight.
 */
enum class FontWeight : uint8_t
{
  /**
   * @brief Thin font weight. Equivalent to weight 100.
   */
  THIN = 0,
  /**
   * @brief Extra light font weight. Equivalent to weight 200.

