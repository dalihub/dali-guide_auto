  }

  /**
   * @brief Queries the number of slots.
   *
   * @SINCE_1_0.0
   * @return The number of slots connected to this signal
   */
  uint32_t GetConnectionCount() const
  {
    return mImpl ? mImpl->GetConnectionCount() : 0;
  }

public:
  SignalMixin()
  : mImpl(nullptr)
  {
  }

  ~SignalMixin()
  {
    delete mImpl;
  }

protected:
  BaseSignal& Impl()
  {
    if(!mImpl)
    {
      mImpl = new BaseSignal();
    }
    return *mImpl;
  }

private:
  BaseSignal* mImpl;
};

