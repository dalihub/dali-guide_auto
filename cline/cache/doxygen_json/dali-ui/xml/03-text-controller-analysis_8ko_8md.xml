<codeline><highlight class="normal">-<sp/>font<sp/>fallback<sp/>/<sp/>validate</highlight></codeline>
<codeline><highlight class="normal">-<sp/>shaping</highlight></codeline>
<codeline><highlight class="normal">-<sp/>glyph<sp/>metrics</highlight></codeline>
<codeline><highlight class="normal">-<sp/>cluster<sp/>mapping</highlight></codeline>
<codeline><highlight class="normal">-<sp/>line<sp/>break<sp/>candidate<sp/>생성</highlight></codeline>
