<codeline></codeline>
<codeline><highlight class="normal">-<sp/>`ALL_OPERATIONS`</highlight></codeline>
<codeline><highlight class="normal">-<sp/>`VALIDATE_FONTS<sp/>|<sp/>SHAPE_TEXT<sp/>|<sp/>GET_GLYPH_METRICS<sp/>|<sp/>LAYOUT<sp/>...`</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">####<sp/>`mTextUpdateInfo`</highlight></codeline>
