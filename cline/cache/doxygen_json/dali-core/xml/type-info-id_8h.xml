    <innerclass refid="classDali_1_1TypeInfoId" prot="public">Dali::TypeInfoId</innerclass>
    <innernamespace refid="namespaceDali">Dali</innernamespace>
    <sectiondef kind="define">
      <memberdef kind="define" id="type-info-id_8h_1a22b17dbea535ab31377910683d334dac" prot="public" static="no">
        <name>DALI_TYPE_ID</name>
        <param><defname>Type</defname></param>
        <initializer><ref refid="classDali_1_1TypeInfoId" kindref="compound">Dali::TypeInfoId</ref>(<ref refid="group__dali__core__object_1gae85752fa2fa9ae70334a99d398e90eca" kindref="member">Dali::HashFNV1a</ref>(#Type), #Type)</initializer>
        <briefdescription>
<para>Macro to create a TypeInfoId from a C++ type at call sites. </para>
        </briefdescription>
        <detaileddescription>
<para>Uses preprocessor stringification (#Type) to obtain the type name and FNV-1a to hash it at compile time. The type must be a complete, named type — not a template parameter token.</para>
<para>Examples of use: <programlisting filename=".cpp"><codeline><highlight class="normal"><ref refid="type-info-id_8h_1a22b17dbea535ab31377910683d334dac" kindref="member">DALI_TYPE_ID</ref>(</highlight><highlight class="keywordtype">int</highlight><highlight class="normal">)<sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>-&gt;<sp/>TypeInfoId(<ref refid="group__dali__core__object_1gae85752fa2fa9ae70334a99d398e90eca" kindref="member">HashFNV1a</ref>(</highlight><highlight class="stringliteral">&quot;int&quot;</highlight><highlight class="normal">),<sp/></highlight><highlight class="stringliteral">&quot;int&quot;</highlight><highlight class="normal">)</highlight></codeline>
<codeline><highlight class="normal"><ref refid="type-info-id_8h_1a22b17dbea535ab31377910683d334dac" kindref="member">DALI_TYPE_ID</ref>(<ref refid="namespaceDali" kindref="compound">Dali</ref>::Actor)<sp/>-&gt;<sp/>TypeInfoId(HashFNV1a(&quot;<ref refid="namespaceDali" kindref="compound">Dali</ref>::Actor&quot;),<sp/>&quot;<ref refid="namespaceDali" kindref="compound">Dali</ref>::Actor&quot;)</highlight></codeline>
</programlisting></para>
<para><simplesect kind="note"><para>Do NOT use this macro inside a template method body where the argument is itself a template parameter (e.g., <ref refid="type-info-id_8h_1a22b17dbea535ab31377910683d334dac" kindref="member">DALI_TYPE_ID(T)</ref> where T is a typename). Use <ref refid="classDali_1_1Any_1ad9deb9f8628d4b38cab86b5fd6aa3b27" kindref="member">Dali::Any::IsType</ref>&lt;T&gt;() for type queries on <ref refid="classDali_1_1Any" kindref="compound">Dali::Any</ref> values, or refer to the <ref refid="classDali_1_1Any" kindref="compound">Dali::Any</ref> class internals which use TypeInfoIdFromTypeid&lt;T&gt;() directly. * The macro uses preprocessor stringification (#Type) to obtain the type name.</para>
</simplesect>
<simplesect kind="return"><para>A TypeInfoId representing the given type @SINCE_2_5.21 </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
