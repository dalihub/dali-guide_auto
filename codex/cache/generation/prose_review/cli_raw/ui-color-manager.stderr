  UiColor outColor;
  bool found = manager.GetBindingColor(view, "TestColor", outColor);
  DALI_TEST_CHECK(found);
  DALI_TEST_EQUALS(outColor.GetColorId(), "Background", TEST_LOCATION);

  END_TEST;
}

