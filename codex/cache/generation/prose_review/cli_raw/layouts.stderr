   * @param[in] internal A pointer to the internal CustomActor
   */
  explicit DALI_UI_API StackLayout(Dali::Internal::CustomActor* internal);
  /// @endcond

public:
  DALI_UI_CHAIN_LAYOUT_METHODS(StackLayout)
};

