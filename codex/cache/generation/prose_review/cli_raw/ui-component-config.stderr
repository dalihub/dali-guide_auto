  UiConfig& SetDpi(int dpi);

  /**
   * @brief Retrieves the screen DPI.
   *
   * @return The dots-per-inch value of the target display
   */
  int GetDpi() const;

  /**
   * @brief Sets the baseline DPI used as the reference for dp calculations.
   *
