ImageView& ImageView::SetAlphaMaskUrl(const Dali::String& maskUrl)
{
  Ui::GetImpl(*this).SetAlphaMaskUrl(maskUrl);
  return *this;
}

Dali::String ImageView::GetAlphaMaskUrl() const
