// accessibility-highlight-overlay.h
#ifndef DALI_UI_ACCESSIBILITY_HIGHLIGHT_OVERLAY_H
#define DALI_UI_ACCESSIBILITY_HIGHLIGHT_OVERLAY_H

/*
 * Copyright (c) 2025 Samsung Electronics Co., Ltd.
 *
