/**
 * @brief Defines a reusable, typed animation specification for View properties.
 *
 * @code
 *   auto spec = View::NewAnimationSpec()
 *     .Opacity(1.0f, 300_ms);
 *   spec.ApplyTo(anim, view);
 * @endcode
 */
class DALI_UI_API ViewAnimationSpec : public BaseHandle
{
public:
  ViewAnimationSpec();
