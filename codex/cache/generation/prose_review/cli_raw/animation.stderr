  ViewAnimationSpec& operator=(ViewAnimationSpec&& rhs) noexcept;

  ////////////////////////////////////////////////////////////////////////////
  // Own properties
  ////////////////////////////////////////////////////////////////////////////

  /**
   * @brief Animates the background color.
   *
