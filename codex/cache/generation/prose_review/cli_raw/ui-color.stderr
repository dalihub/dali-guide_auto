  UiColor color("Primary");
  UiColor result = color.ScaleAlpha(0.5f);

  // The result should still have a color ID
  DALI_TEST_CHECK(result.HasColorId());
  DALI_TEST_EQUALS(result.GetColorId(), "Primary", TEST_LOCATION);


