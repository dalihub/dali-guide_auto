#include <dali-ui-foundation/public-api/trait-id.h>

// EXTERNAL INCLUDES
#include <atomic>

namespace Dali
{
namespace Ui
{

TraitId TraitId::Alloc()
{
  static std::atomic<uint32_t> counter{0};
  return TraitId{counter.fetch_add(1u, std::memory_order_relaxed)};
}

} // namespace Ui
} // namespace Dali

