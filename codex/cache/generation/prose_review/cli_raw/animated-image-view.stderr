void AnimatedImageViewImpl::SetLoadPolicy(Ui::Image::LoadPolicy loadPolicy)
{
  if(mLoadPolicy != loadPolicy)
  {
    mLoadPolicy = loadPolicy;
    if(mLoadPolicy == Ui::Image::LoadPolicy::IMMEDIATE && (!mUrl.Empty() || !mUrls.Empty()))
    {
      mVisualDirty = false;
      UpdateVisual();
    }
    else
    {
      mVisualDirty = true;
      InvalidateMeasure();
    }
  }
}

