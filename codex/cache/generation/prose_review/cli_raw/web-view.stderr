  bool CheckVideoPlayingAsynchronously(VideoPlayingCallback callback);

public: // JavaScript
  /**
   * @brief Evaluates JavaScript code.
   *
   * @param[in] script The JavaScript code to evaluate
   */
  void EvaluateJavaScript(const Dali::String& script);

  /**
