      if(currentColor == UiColor(COLOR_DARK_GRAY))
      {
        mInputField.SetPlaceholderColor(UiColor(COLOR_LIGHT_BLUE));
      }
      else if(currentColor == UiColor(COLOR_LIGHT_BLUE))
      {

