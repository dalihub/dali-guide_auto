  DALI_TEST_CHECK(child.IsEffectivelyEnabled());

  parent.SetEnabled(false);

  DALI_TEST_CHECK(!child.IsEffectivelyEnabled());
  DALI_TEST_CHECK(child.IsEnabled()); // own state unchanged

  END_TEST;
}

