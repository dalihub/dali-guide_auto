bool DefaultExecutionKeyPredicate(const Dali::String& keyName)
{
  return keyName == "Return";
}

#if defined(DEBUG_ENABLED)
Debug::Filter* gLogFilter = Debug::Filter::New(Debug::NoLogging, false, "LOG_UI_CONFIG");
#endif

} // unnamed namespace

namespace Dali
{

namespace Ui
{

