  ULTRA_BOLD = EXTRA_BOLD,
  /**
   * @brief Black font weight. Equivalent to weight 900.
   */
  BLACK = 10,
  /**
   * @brief Heavy font weight. Alias of BLACK.
   */
  HEAVY = BLACK
};

