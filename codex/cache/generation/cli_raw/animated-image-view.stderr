const char* const ImageAlphaMaskController::ANIMATED_URL = RESOURCES_DIR "dali-logo-anim.gif";

const ImageAlphaMaskController::MaskEntry ImageAlphaMaskController::MASKS[ImageAlphaMaskController::MASK_COUNT] = {

