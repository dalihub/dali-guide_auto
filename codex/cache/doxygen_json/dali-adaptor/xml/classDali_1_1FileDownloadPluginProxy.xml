        <detaileddescription>
<para>Download a requested file into a memory buffer.</para>
<para>Attempts to load and use the registered file download plugin. If the plugin cannot be loaded, returns false and logs appropriate messages.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">url</parametername>
</parameternamelist>
<parameterdescription>
<para>The requested file URL </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">dataBuffer</parametername>
</parameternamelist>
<parameterdescription>
<para>A memory buffer object to be written with downloaded file data. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">dataSize</parametername>
</parameternamelist>
<parameterdescription>
<para>The size of the memory buffer. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">maximumAllowedSizeBytes</parametername>
</parameternamelist>
<parameterdescription>
<para>The maximum allowed file size in bytes to download. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>true on success, false on failure (including plugin unavailable) </para>
</simplesect>
</para>
